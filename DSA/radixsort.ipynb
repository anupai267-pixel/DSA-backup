    "def radix_sort(arr):\n",
    "    arr.sort()      # Built-in sorting\n",
    "\n",
    "    return arr\n",
    "\n",
    "nums = [23, 5, 89, 12, 45]\n",
    "\n",
    "print(\"Before:\", nums)\n",
    "print(\"After :\", radix_sort(nums))"
   ]
